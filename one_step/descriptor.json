{
    "name": "samseg_long_onestep",
    "description": "SAMSEG longitudinal segmentation via niwrap, one unified step per participant: runs mri_robust_template (BIDS T1w -> unbiased template) then run_samseg_long (template-space images -> longitudinal segmentation). Sessions auto-discovered.",
    "tool-version": "1.0.0",
    "schema-version": "0.5",
    "command-line": "python [SCRIPT_PATH] [BIDS_DIR] [OUTPUT_DIR] [PARTICIPANT_ID]",
    "inputs": [
        {
            "id": "script_path",
            "name": "script_path",
            "description": "Path to the script to run (shipped inside the pipeline bundle).",
            "optional": false,
            "type": "String",
            "value-key": "[SCRIPT_PATH]"
        },
        {
            "id": "bids_dir",
            "name": "bids_dir",
            "description": "Root of the BIDS dataset.",
            "optional": false,
            "type": "String",
            "value-key": "[BIDS_DIR]"
        },
        {
            "id": "output_dir",
            "name": "output_dir",
            "description": "Output directory (results go under <output_dir>/<sub>/).",
            "optional": false,
            "type": "String",
            "value-key": "[OUTPUT_DIR]"
        },
        {
            "id": "participant_id",
            "name": "participant_id",
            "description": "Participant label, with or without the sub- prefix.",
            "optional": false,
            "type": "String",
            "value-key": "[PARTICIPANT_ID]"
        }
    ],
    "tags": {},
    "suggested-resources": {
        "cpu-cores": 2,
        "ram": 8,
        "walltime-estimate": 120
    }
}
